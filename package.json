{
  "name": "pixel-art",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "mprocs",
    "dev:client": "cd client && bun run dev",
    "dev:server": "cd server && bun run dev",
    "build": "cd client && bun run build",
    "install:all": "bun install && cd client && bun install && cd ../server && bun install",
    "ai:setup": "cd ai-service && ./setup.sh",
    "ai:run": "cd ai-service && python server.py",
    "ai": "bun run ai:start",
    "ai:start": "bun run ai:setup && bun run ai:run"
  },
  "devDependencies": {
    "mprocs": "^0.8.3",
    "sharp": "0.34.5"
  }
}
