# AI Frame Interpolation Service URL
# Set this to point the Express server proxy at a remote AI service.
# If unset, defaults to http://localhost:8100
# AI_SERVICE_URL=http://localhost:8100

# Express server port (default: 3001)
# PORT=3001

# Client: base URL of the Express server API.
# Set this when the Express server is hosted at a different address than the
# client (e.g. production or remote development). When unset the client uses
# relative paths which are proxied by Vite in dev mode.
# VITE_API_URL=http://localhost:3001/api
